{
	"name": "pascal-uses-formatter",
	"displayName": "pascal-uses-formatter",
	"description": "sorts the uses section in pascal files",
	"version": "0.3.1",
	"publisher": "tuncb",
	"repository": "https://github.com/tuncb/delphi-uses-formatter",
	"license": "Apache-2.0",
	"engines": {
		"vscode": "^1.70.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onLanguage:pascal",
		"onLanguage:objectpascal",
		"onCommand:pascal-uses-formatter.formatUses"
	],
	"main": "./out/extension",
	"contributes": {
		"commands": [
			{
				"command": "pascal-uses-formatter.formatUses",
				"title": "Format uses section"
			}
		],
		"configuration": {
			"title": "pascal-uses-formatter",
			"properties": {
				"pascal-uses-formatter.formatOnSave": {
					"type": "boolean",
					"default": true,
					"description": "Format uses section automatically after first activation"
				},
				"pascal-uses-formatter.overrideSortingOrder": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Override default namespace sorting order. Configure sorting priority by adding namespace to array"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint -c .eslintrc.js --ext .ts ./src",
		"pretest": "npm run compile",
		"test": "vscode-test",
		"deploy": "vsce publish -p"
	},
	"devDependencies": {
		"@vscode/test-cli": "^0.0.12",
		"@types/chai": "^4.1.7",
		"@types/glob": "^7.1.1",
		"@types/mocha": "^10.0.1",
		"@types/node": "^16.11.7",
		"@types/vscode": "^1.70.0",
		"@typescript-eslint/eslint-plugin": "^5.34.0",
		"@typescript-eslint/parser": "^5.34.0",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"chai": "^4.2.0",
		"eslint": "^8.22.0",
		"glob": "^7.1.4",
		"mocha": "^11.7.5",
		"source-map-support": "^0.5.12",
		"typescript": "^4.7.4"
	},
	"dependencies": {
		"ci": "^2.2.0"
	},
	"overrides": {
		"diff": "^8.0.3",
		"serialize-javascript": "^7.0.4",
		"xml2js": "^0.6.2",
		"yauzl": "^3.2.1",
		"tmp": "^0.2.5"
	},
	"__metadata": {
		"id": "4a2df659-b302-45e0-aff3-b09ca8698fc1",
		"publisherDisplayName": "tuncb",
		"publisherId": "6bd27f37-02dd-486a-9ce9-ceb53ee4f81c",
		"isPreReleaseVersion": false
	}
}